---
import BaseLayout from "@/layouts/BaseLayout.astro";
import DiffCheckerTool from "@/components/tools/diff-checker";
import StructuredData from "@/components/StructuredData.astro";

const title = "Diff Checker - Compare Text Differences | pavi2410";
const description = "A powerful diff checker tool to compare text with line, word, or character-level strategies. Features include ignore case, ignore whitespace, hunk-based viewing, and unified diff export.";
const permalink = "/tools/diff-checker/";
const features = [
  "Line, word, and character-level diff strategies",
  "Ignore case and whitespace options",
  "Hunk-based side-by-side viewing",
  "Unified diff export",
  "Syntax highlighting",
  "Privacy-first: text never leaves your device",
];
---

<BaseLayout
  title={title}
  description={description}
  permalink={permalink}
>
  <StructuredData
    type="softwareApplication"
    data={{ name: "Diff Checker", description, url: permalink, features }}
  />
  <style>
    body {
      overflow: hidden;
    }
  </style>

  <div class="fixed inset-0 flex flex-col bg-white dark:bg-gray-950">
    <!-- App Header -->
    <div class="shrink-0 border-b border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950">
      <div class="px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <a
            href="/tools"
            class="text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
            title="Back to tools"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
          </a>
          <div>
            <h1 class="text-lg font-bold text-gray-900 dark:text-gray-100">
              Diff Checker
            </h1>
            <p class="text-xs text-gray-500 dark:text-gray-400">
              Compare text differences
            </p>
          </div>
        </div>
        <a
          href="/"
          class="text-sm font-medium text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100"
        >
          pavi2410.com
        </a>
      </div>
    </div>

    <!-- App Content -->
    <div class="flex-1 overflow-hidden">
      <DiffCheckerTool client:load />
    </div>
  </div>

  <section class="sr-only">
    <h2>Diff Checker Features</h2>
    <ul>
      {features.map(f => <li>{f}</li>)}
    </ul>
  </section>
</BaseLayout>
